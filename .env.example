# ============================================================
# Cosme Check - Variables d'environnement
# ------------------------------------------------------------
# 1. Renomme ce fichier en `.env.local` (Next.js) ou `.env`
# 2. Remplis les valeurs ci-dessous
# 3. NE JAMAIS COMMITER le fichier rempli (déjà dans .gitignore)
# ============================================================

# --- Site URL (utilisée pour metadataBase, sitemap, robots, JSON-LD) ---
# En prod : https://ton-domaine.com (sans slash final)
# En local : laisse vide (fallback https://cosme-check.vercel.app)
NEXT_PUBLIC_SITE_URL=

# --- Supabase (base de données partagée, schéma `cosme_check` isolé) ---
# Récupère ces valeurs dans : Supabase Dashboard > Project Settings > API
# IMPORTANT : pour que le sitemap.xml liste tous les ingrédients,
# expose le schéma `cosme_check` dans Dashboard > Project Settings > API > Exposed schemas.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Service role key : SECRET, côté serveur uniquement, JAMAIS préfixée NEXT_PUBLIC_
SUPABASE_SERVICE_ROLE_KEY=

# URL de connexion directe PostgreSQL (pour les migrations SQL et le scraping batch)
# Format : postgresql://postgres:[PASSWORD]@db.[REF].supabase.co:5432/postgres
SUPABASE_DB_URL=

# --- Anti-bot (hCaptcha free tier - alternative à Cloudflare Turnstile) ---
# Inscription gratuite sur https://www.hcaptcha.com/
NEXT_PUBLIC_HCAPTCHA_SITE_KEY=
HCAPTCHA_SECRET_KEY=

# --- Scraping (User-Agent custom poli pour les requêtes de collecte de fiches produits) ---
SCRAPER_USER_AGENT=Cosme-Check-bot/1.0 (contact@example.com)

# --- Optionnel : taille de batch et délai entre requêtes du scraper ---
SCRAPER_BATCH_SIZE=50
SCRAPER_DELAY_MS=800

# --- Mistral (synthèses IA + extraction INCI depuis pages produit) ---
# Clé gratuite sur https://console.mistral.ai/
MISTRAL_API_KEY=

# --- Brevo (synchro des inscrits vers Brevo) ---
# Clé API v3 REST. Génère-la sur : https://app.brevo.com/settings/keys/api
# (Paramètres → SMTP et API → onglet « Clés API et MCP » → Générer une clé).
# Côté serveur uniquement, JAMAIS préfixée NEXT_PUBLIC_.
# Si vide : l'inscription fonctionne quand même, la synchro Brevo est simplement
# ignorée (fail-open). En prod : `vercel env add BREVO_API_KEY`.
BREVO_API_KEY=
# IDs des 2 listes Brevo. « ALL » = tous les inscrits (communications de service) ;
# « NEWSLETTER » = uniquement les opt-in marketing. Si vides, les listes sont
# retrouvées par leur nom (« Cosme Check — Tous les inscrits » / « … Newsletter »).
BREVO_LIST_ALL_ID=
BREVO_LIST_NEWSLETTER_ID=
# Programme bêta : liste dédiée « Cosme Check — Bêta testeurs » (page /beta).
BREVO_BETA_LIST_ID=
# Expéditeur des emails transactionnels (doit être un expéditeur vérifié Brevo).
BREVO_SENDER_EMAIL=contact@cosme-check.com
# Secret partagé avec CosmeCheckAdmin (bouton « Envoyer les invitations » →
# POST /api/beta/invite). Doit être IDENTIQUE dans les deux projets.
BETA_INVITE_SECRET=
# Templates transactionnels Brevo du programme bêta (IDs dans Brevo →
# Campagnes → Modèles). Le contenu se modifie dans l'UI Brevo sans redéploiement.
BREVO_TPL_BETA_ACCESS=1
BREVO_TPL_BETA_RELANCE=2
BREVO_TPL_BETA_FEEDBACK=3
BREVO_TPL_BETA_MERCI=4
# CRON quotidien des relances bêta (/api/beta/cron, cf. vercel.json). Vercel
# envoie `Authorization: Bearer $CRON_SECRET` automatiquement.
CRON_SECRET=
# MODE TEST des relances : poser =minutes pour que les délais (2/3/5) comptent
# en MINUTES au lieu de jours → tester le parcours en quelques minutes. Laisser
# vide (ou =days) en production. À retirer après le test.
BETA_RELANCE_UNIT=

# --- Brevo MCP (pour piloter Brevo depuis Claude Code, cf. .mcp.json) ---
# CE N'EST PAS lu par l'app. C'est le token Bearer du serveur MCP Brevo, à
# exposer comme variable d'environnement système (setx BREVO_MCP_TOKEN "..."
# sur Windows), pas dans ce fichier. Génère une clé API AVEC l'option MCP
# activée sur https://app.brevo.com/settings/keys/api
# BREVO_MCP_TOKEN=  (variable d'env OS, pas ici)
